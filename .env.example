# Portfolio AI chat (optional, free).
# Get a free key from https://console.groq.com (no credit card) and set these
# in Vercel → Project → Settings → Environment Variables. Without them the chat
# still renders and shows a graceful fallback.

LLM_API_KEY=
# Defaults below work with Groq's free tier; override to use another
# OpenAI-compatible provider (e.g. Google Gemini, OpenRouter).
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
